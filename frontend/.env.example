# Copy this to .env.local for local dev (uses Vite proxy, leave VITE_API_URL empty)
# For production, set VITE_API_URL in your Vercel project environment variables

# Leave empty in dev (Vite proxy handles it)
# Set to your Railway backend URL in production, e.g.:
# VITE_API_URL=https://your-backend.railway.app
VITE_API_URL=
